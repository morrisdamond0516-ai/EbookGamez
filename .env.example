# Copy this file to .env and fill in your values.

# PostgreSQL (required)
# Create the database first: createdb ebookgamez  (or via pgAdmin)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ebookgamez

# App auth (required)
ADMIN_PASSWORD=your-admin-password
SESSION_SECRET=generate-a-long-random-string

# OpenAI — use your direct API key for local dev (required for AI features)
OPENAI_API_KEY=sk-...

# Replit AI integration (production/Replit only — leave unset for local dev)
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# Stripe (required for payments/subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Object storage (Replit production only — local dev uses uploads/ folder)
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket-id/your-bucket-name
#
# Cursor/local workflow:
# - Covers save to uploads/covers/ and DB gets /uploads/covers/... URLs (not fake /objstore/ paths).
# - npm run build does NOT delete uploads/ locally — only on Replit deploy (when PUBLIC_OBJECT_SEARCH_PATHS is set).
# - Story text lives in PostgreSQL (draft_ebooks.content) — safe across builds.
# - After generating on Cursor, deploy to Replit; startup uploads local files to GCS automatically.

# Analytics (optional)
# GA4_MEASUREMENT_ID=
# VITE_MICROSOFT_UET_TAG_ID=

# Local dev
NODE_ENV=development
HOST=127.0.0.1
PORT=3000

# Prevents auto bulk-write, illustration queue, bulk publish, and dialogue recheck on npm run dev.
# On by default when NODE_ENV=development. Replit production: leave unset or set ENABLE_STARTUP_AUTO_RESUME=true.
DISABLE_STARTUP_AUTO_RESUME=true
