modules = ["nodejs-20", "python-3.11", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["cairo", "pango", "libjpeg", "giflib", "librsvg", "pixman", "libuuid", "libGL", "poppler_utils", "zip", "unzip", "chromium", "wget"]

[[ports]]
localPort = 5000
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8000
externalPort = 8000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["node", "dist/index.cjs"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 2; NODE_OPTIONS='--max-old-space-size=2048' npm run dev"
waitForPort = 5000

[agent]
mockupState = "FULLSTACK"
integrations = ["stripe:2.0.0", "javascript_openai_ai_integrations:2.0.0", "perplexity_v0:1.0.0", "javascript_object_storage:2.0.0", "resend:1.0.0"]

[userenv]

[userenv.shared]
VITE_MICROSOFT_UET_TAG_ID = "YOUR_TAG_ID_HERE"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[objectStorage]
defaultBucketID = "replit-objstore-b9077d24-cc97-4157-acd6-c12594d1b438"
